# Supabase — find these in your project at Settings → API
# SUPABASE_URL is the "Project URL".
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# SERVICE ROLE key — server-only, bypasses RLS. NEVER prefix with NEXT_PUBLIC_
# and never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# CRM (optional — leave blank until you're ready to connect it)
# When set, leads are forwarded here after they're saved to Supabase.
CRM_WEBHOOK_URL=
CRM_API_KEY=
