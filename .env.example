# Supabase — find these in your project at Settings → API
# SUPABASE_URL is the "Project URL".
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Publishable (anon) key — safe to use server-side. The leads table has RLS
# with an insert-only policy, so this key can only write leads, never read them.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# CRM (optional — leave blank until you're ready to connect it)
# When set, leads are forwarded here after they're saved to Supabase.
CRM_WEBHOOK_URL=
CRM_API_KEY=
